{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/writing/layout,_N_T_/writing/product-discovery/layout,_N_T_/writing/product-discovery/page,_N_T_/writing/product-discovery"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/writing/product-discovery/__PAGE__",
    "/writing/product-discovery",
    "/writing",
    "/_index",
    "/_head"
  ]
}