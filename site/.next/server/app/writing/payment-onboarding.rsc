{"style":{"fontSize":14,"fontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]],[]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","footer",null,{"className":"border-t border-[var(--border)] mt-32","children":["$","div",null,{"className":"max-w-layout mx-auto px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-4","children":[["$","p",null,{"className":"text-sm text-[var(--muted)]","children":["© ",2026," Femi Siji-Kenneth"]}],["$","div",null,{"className":"flex items-center gap-6","children":[["$","a",null,{"href":"mailto:oluwafemiakinseye@gmail.com","className":"text-sm text-[var(--muted)] hover:text-[var(--text)] transition-colors","children":"Email"}],["$","a",null,{"href":"https://linkedin.com/in/","target":"_blank","rel":"noopener noreferrer","className":"text-sm text-[var(--muted)] hover:text-[var(--text)] transition-colors","children":"LinkedIn"}],["$","a",null,{"href":"https://github.com/","target":"_blank","rel":"noopener noreferrer","className":"text-sm text-[var(--muted)] hover:text-[var(--text)] transition-colors","children":"GitHub"}]]}]]}]}]]}]}]}]]}],{"children":[["$","$1","c",{"children":[null,["$","$L4",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":[["$","$1","c",{"children":[null,["$","$L4",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":[["$","$1","c",{"children":[["$","$L6",null,{"title":"Why Payment Onboarding Is a Product Problem, Not a Compliance Problem","date":"2025-04-15","readTime":"7 min read","children":[["$","p",null,{"children":"Every payment company I know has a version of the same conversation: the compliance team comes to the product team with a list of required fields, and the product team puts those fields in a form. The form goes live. Activation rates are terrible. The compliance team says the product team implemented it wrong. The product team says they followed the spec."}],["$","p",null,{"children":"They're both right, and they're both missing the point."}],["$","h2",null,{"children":"The compliance team is not your enemy"}],["$","p",null,{"children":"KYB (Know Your Business) and KYC (Know Your Customer) requirements exist for real reasons. Financial crime, money laundering, and fraud are problems that regulators have learned, the hard way, that you can't prevent without verified identity. The requirements aren't arbitrary bureaucracy — they're the output of decades of case law and incident analysis."}],"$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18"]}],["$L19","$L1a"],"$L1b"]}],{},null,false,false]},null,false,false]},null,false,false]},null,false,false],"$L1c",false]],"m":"$undefined","G":["$1d",[]],"S":true}
