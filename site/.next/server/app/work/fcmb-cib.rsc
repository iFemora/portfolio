ontWeight":400,"lineHeight":"49px","margin":0},"children":"This page could not be found."}]}]]}]}]],[]],"forbidden":"$undefined","unauthorized":"$undefined"}]}],["$","footer",null,{"className":"border-t border-[var(--border)] mt-32","children":["$","div",null,{"className":"max-w-layout mx-auto px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-4","children":[["$","p",null,{"className":"text-sm text-[var(--muted)]","children":["© ",2026," Femi Siji-Kenneth"]}],["$","div",null,{"className":"flex items-center gap-6","children":[["$","a",null,{"href":"mailto:oluwafemiakinseye@gmail.com","className":"text-sm text-[var(--muted)] hover:text-[var(--text)] transition-colors","children":"Email"}],["$","a",null,{"href":"https://linkedin.com/in/","target":"_blank","rel":"noopener noreferrer","className":"text-sm text-[var(--muted)] hover:text-[var(--text)] transition-colors","children":"LinkedIn"}],["$","a",null,{"href":"https://github.com/","target":"_blank","rel":"noopener noreferrer","className":"text-sm text-[var(--muted)] hover:text-[var(--text)] transition-colors","children":"GitHub"}]]}]]}]}]]}]}]}]]}],{"children":[["$","$1","c",{"children":[null,["$","$L4",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":[["$","$1","c",{"children":[null,["$","$L4",null,{"parallelRouterKey":"children","error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":[["$","$1","c",{"children":[["$","$L6",null,{"title":"FCMB Corporate Internet Banking","role":"Lead Product Manager","year":"2024","company":"First City Monument Bank","tags":["Banking","B2B","Operations","Nigeria"],"outcomes":[{"label":"Revenue Growth","value":"3×"},{"label":"Onboarding Time","value":"10 → 3 days"},{"label":"Manual Approvals","value":"7 → 2 steps"},{"label":"Active Corporates","value":"+40% YoY"}],"children":[["$","h2",null,{"children":"Context"}],["$","p",null,{"children":"FCMB's Corporate Internet Banking (CIB) platform served hundreds of Nigerian businesses — from SMEs to large corporates — managing payroll runs, bulk transfers, and treasury operations. By the time I joined, the platform had become a source of friction rather than value. Finance directors were calling account managers just to approve a single transaction."}],["$","p",null,{"children":"The core problem wasn't the technology. It was that the product had been built around compliance checklists rather than how corporate treasurers and their teams actually worked."}],"$L7","$L8","$L9","$La","$Lb","$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16","$L17","$L18","$L19","$L1a","$L1b"]}],["$L1c","$L1d"],"$L1e"]}],{},null,false,false]},null,false,false]},null,false,false]},null,false,false],"$L1f",false]],"m":"$undefined","G":["$20",[]],"S":true}
