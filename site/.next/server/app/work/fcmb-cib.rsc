27:[["$","title","0",{"children":"FCMB Corporate Internet Banking | Femi Siji-Kenneth"}],["$","meta","1",{"name":"description","content":"How I redesigned the onboarding and approval flows for FCMB's corporate banking platform, cutting onboarding from 10 days to 3 and driving 3× revenue growth."}],["$","meta","2",{"name":"robots","content":"index, follow"}],["$","meta","3",{"property":"og:title","content":"Femi Siji-Kenneth — Product Manager"}],["$","meta","4",{"property":"og:description","content":"Product Manager with deep experience in payment infrastructure and fintech for emerging markets."}],["$","meta","5",{"property":"og:url","content":"https://femisiji-kenneth.com"}],["$","meta","6",{"property":"og:site_name","content":"Femi Siji-Kenneth"}],["$","meta","7",{"property":"og:locale","content":"en_US"}],["$","meta","8",{"property":"og:type","content":"website"}],["$","meta","9",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","10",{"name":"twitter:title","content":"Femi Siji-Kenneth — Product Manager"}],["$","meta","11",{"name":"twitter:description","content":"PM building payment infrastructure for emerging markets."}],["$","link","12",{"rel":"icon","href":"/favicon.ico?favicon.0b3bf435.ico","sizes":"256x256","type":"image/x-icon"}],["$","$L28","13",{}]]
